; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GAMEDEV_FINALS"
run/main_scene="uid://c8ylyl4q2ye2q"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="uid://dcoiis6w8k6rt"

[autoload]

CursorManager="*res://CursorManager.gd"
AudioManager="*res://Assets/Audio/AudioManager.tscn"
GlobalManager="*res://global_manager.tscn"
Inventory="*res://InventoryManager.gd"
InventoryUi="*res://inventory_ui.tscn"
SceneChanger="*res://Scenes/ExtraScenes/scene_changer.tscn"

[display]

window/size/mode=3
window/stretch/mode="viewport"

[editor]

version_control/plugin_name="GitPlugin"
version_control/autoload_on_startup=true

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
